# Backend Environment Variables
# Copy this file to .env.local for local development
# Copy to .env for production with appropriate values

# ======================
# SERVER CONFIGURATION
# ======================
NODE_ENV=development
PORT=5000

# ======================
# DATABASE CONFIGURATION
# ======================
DB_HOST=localhost
DB_PORT=5432
DB_USER=aggimallaabhishek
DB_PASSWORD=
DB_NAME=taskmaster

# Database Connection Pool Settings (for production)
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT=30000
DB_POOL_CONNECT_TIMEOUT=5000

# ======================
# SESSION CONFIGURATION
# ======================
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your-secret-key-change-in-production
SESSION_TIMEOUT=3600000

# ======================
# GOOGLE OAUTH CONFIGURATION (Optional)
# ======================
# Get these from: https://console.cloud.google.com/apis/dashboard
# GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# GOOGLE_CALLBACK_URL=http://localhost:5000/auth/google/callback

# ======================
# FRONTEND URLS (for CORS)
# ======================
FRONTEND_URL_DEV=http://localhost:5173
FRONTEND_URL_PROD=https://your-vercel-domain.vercel.app
CORS_ORIGIN=http://localhost:5173

# ======================
# API CONFIGURATION
# ======================
# Rate limiting (in milliseconds)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ======================
# LOGGING
# ======================
LOG_LEVEL=info
LOG_FORMAT=json

# ======================
# FEATURES
# ======================
ENABLE_SWAGGER_DOCS=true
ENABLE_HEALTH_CHECK=true
